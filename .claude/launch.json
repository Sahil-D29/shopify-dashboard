{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Express Backend API",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "port": 5000,
      "cwd": "backend"
    },
    {
      "name": "Next.js Dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3002,
      "cwd": "backend/shopify-dashboard"
    },
    {
      "name": "React Frontend (Legacy)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "cwd": "frontend"
    }
  ]
}
